# App
VITE_APP_VERSION=1.0.0-beta

# Auth / Database
DATABASE_URL="postgresql://user:password@localhost:5432/nutripilot"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_a_secure_random_string"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email Provider (SMTP URL format)
# Example: smtp://user:pass@smtp.sendgrid.net:587
EMAIL_SERVER=""
EMAIL_FROM="NutriPilot <no-reply@nutripilot.com>"

# Resend Email API (preferred over SMTP — https://resend.com)
RESEND_API_KEY=""

# Stripe (premium gating readiness)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Analytics (PostHog)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Analytics (GA4 BigQuery export for weekly funnel report)
GA4_BQ_PROJECT_ID=""
GA4_BQ_DATASET=""
GA4_BQ_LOCATION="US"

# Error Monitoring (Sentry)
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Waitlist
VITE_WAITLIST_WEBHOOK_URL=

# Final Feature Flags
VITE_FLAG_ANALYTICS=true
VITE_FLAG_ERROR_MONITORING=true
VITE_FLAG_WAITLIST_CAPTURE=true
VITE_FLAG_PREMIUM_MONETIZATION_V2=false
VITE_FLAG_WEEKLY_COACH_PREMIUM_ONLY=false
