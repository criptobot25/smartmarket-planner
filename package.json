{
  "name": "nutripilot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run validate:blog",
    "build": "next build",
    "start": "next start",
    "preview": "next start",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "playwright test",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "validate:blog": "node scripts/validate-blog-frontmatter.mjs",
    "report:funnel:weekly": "node scripts/weekly-funnel-report.mjs",
    "blog:new": "node scripts/new-blog-post.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@google-cloud/bigquery": "^8.1.1",
    "@prisma/client": "^6.16.3",
    "@sentry/react": "^10.39.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "gray-matter": "^4.0.3",
    "html-to-image": "^1.11.13",
    "i18next": "^25.8.7",
    "jspdf": "^4.1.0",
    "next": "^14.2.30",
    "next-auth": "^4.24.13",
    "next-mdx-remote": "^6.0.0",
    "posthog-js": "^1.350.0",
    "prisma": "^6.16.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^6.21.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.2.30",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^28.0.0",
    "typescript": "^5.2.2",
    "vitest": "^4.0.18"
  }
